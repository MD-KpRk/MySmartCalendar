datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id              Int       @id @default(autoincrement())
  telegramId      BigInt    @unique
  telegramUsername String?
  firstName       String
  lastName        String?
  timezone        String    @default("Europe/Moscow")
  notifyEnabled   Boolean   @default(true)
  dailySummaryTime String   @default("08:00")  // HH:MM в 24-часовом формате
  createdAt       DateTime  @default(now())
  
  events          Event[]
  tasks           Task[]
  reminders       Reminder[]
  habits          Habit[]
  habitLogs       HabitLog[]
  notes           Note[]
  shifts          ShiftProfile[]
  monthlySchedules MonthlySchedule[]
  aiConversations AiConversation[]
  notificationSettings NotificationSetting[]
}

model Event {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean   @default(false)
  color       String?
  recurrence  Json?     // Хранение правил повторения (например, RRULE в JSON)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          Int         @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  deadline    DateTime?
  status      TaskStatus  @default(PENDING)
  priority    Priority    @default(MEDIUM)
  tags        String[]
  createdAt   DateTime    @default(now())
  completedAt DateTime?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  remindAt    DateTime
  sent        Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id          Int        @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  frequency   String     // "daily", "weekly"
  targetDays  Int[]      // Дни недели: 0 (воскресенье) - 6 (суббота)
  createdAt   DateTime   @default(now())
  logs        HabitLog[]
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  userId    Int
  date      DateTime @db.Date
  completed Boolean  @default(false)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String?
  content   String
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Базовый шаблон смен пользователя
model ShiftProfile {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String   @default("Основной")
  pattern     ShiftType[] // Массив типов смен: [DAY, NIGHT, SLEEP, OFF]
  startDate   DateTime @db.Date // С какой даты начинается отсчет паттерна
  isDefault   Boolean  @default(true)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Сетка смен на конкретный месяц с подтверждением
model MonthlySchedule {
  id          Int         @id @default(autoincrement())
  userId      Int
  year        Int
  month       Int         // 1-12
  confirmed   Boolean     @default(false)
  days        ShiftDay[]
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
}

model ShiftDay {
  id                Int             @id @default(autoincrement())
  monthlyScheduleId Int
  date              DateTime        @db.Date
  shiftType         ShiftType
  note              String?
  schedule          MonthlySchedule @relation(fields: [monthlyScheduleId], references: [id], onDelete: Cascade)

  @@unique([monthlyScheduleId, date])
}

model AiConversation {
  id        Int        @id @default(autoincrement())
  userId      Int
  messages  Json       // [{role: "user"|"assistant"|"system", content: string, createdAt: date}]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSetting {
  id            Int      @id @default(autoincrement())
  userId        Int
  type          NotifType
  enabled       Boolean  @default(true)
  minutesBefore Int?     // для напоминаний о событиях
  time          String?  // "HH:MM" для сводок
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ShiftType {
  DAY
  NIGHT
  SLEEP
  OFF
}

enum NotifType {
  EVENT_REMINDER
  DAILY_SUMMARY
  WEEKLY_PLAN
  UNFINISHED_TASKS
}


